# Minimal sshd config for a user-launched sshd inside a SLURM job.
# All non-essential defaults intentionally dropped — DO NOT add
# `Include /etc/ssh/sshd_config.d/*.conf` here. Drop-ins on the
# compute node are exactly the kind of silent regression this avoids.

# Port is set via -p on the command line.
# HostKey is set via -h on the command line.

PubkeyAuthentication yes
PasswordAuthentication no
ChallengeResponseAuthentication no
KbdInteractiveAuthentication no
UsePAM no
PermitUserEnvironment no

# data/ssh_config/ lives on NFS under the project tree; default StrictModes
# rejects it for "bad ownership/perms". We control this directory so it is safe.
StrictModes no

AuthorizedKeysFile __AuthorizedKeysFile__

PrintMotd no
PrintLastLog no
X11Forwarding yes
AllowTcpForwarding yes
PermitTTY yes
AcceptEnv LANG LC_*

Subsystem sftp /usr/lib/openssh/sftp-server
